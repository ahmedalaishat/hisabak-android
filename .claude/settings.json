{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-tests.sh\"",
            "timeout": 300,
            "asyncRewake": true,
            "rewakeSummary": "Unit tests failed",
            "rewakeMessage": "The unit suite failed after your last change — fix it:"
          }
        ]
      }
    ]
  }
}
