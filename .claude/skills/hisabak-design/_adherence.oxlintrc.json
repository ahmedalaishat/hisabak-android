{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:DM Sans|Geist Mono|Material Symbols Rounded))/i]",
        "message": "Font not provided by the design system. Available: DM Sans, Geist Mono, Material Symbols Rounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='AmountText'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|text|currency|sign|tone|size|weight|style|key|ref|className|style|children)$/]",
        "message": "<AmountText> doesn't accept that prop. Declared props: value, text, currency, sign, tone, size, weight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AmountText'] > JSXAttribute[name.name='sign'] > Literal[value!=/^(?:auto|always|never)$/]",
        "message": "<AmountText> sign must be one of 'auto' | 'always' | 'never'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AmountText'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:auto|income|expense|savings|investment|neutral)$/]",
        "message": "<AmountText> tone must be one of 'auto' | 'income' | 'expense' | 'savings' | 'investment' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|income|expense|savings|investment|success|warning|danger|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'income' | 'expense' | 'savings' | 'investment' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<NavTab> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|leadingIcon|trailingIcon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, leadingIcon, trailingIcon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|tint|padding|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, tint, padding, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|hero|flat|tinted)$/]",
        "message": "<Card> variant must be one of 'default' | 'hero' | 'flat' | 'tinted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|color|size|style|key|ref|className|style|children)$/]",
        "message": "<CategoryIcon> doesn't accept that prop. Declared props: icon, color, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|icon|color|type|total|onDelete|onClick|addNew|style|key|ref|className|style|children)$/]",
        "message": "<CategoryTile> doesn't accept that prop. Declared props: name, icon, color, type, total, onDelete, onClick, addNew, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:income|expense|savings|investment)$/]",
        "message": "<CategoryTile> type must be one of 'income' | 'expense' | 'savings' | 'investment'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|color|leadingIcon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, selected, color, leadingIcon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|variant|filled|ariaLabel|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, variant, filled, ariaLabel, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|soft|accent)$/]",
        "message": "<IconButton> variant must be one of 'plain' | 'soft' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|placeholder|leadingIcon|helper|error|type|multiline|rows|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, value, placeholder, leadingIcon, helper, error, type, multiline, rows, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|leadingText|leadingIcon|color|amount|amountTone|meta|trailing|onClick|divider|style|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: title, subtitle, leadingText, leadingIcon, color, amount, amountTone, meta, trailing, onClick, divider, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute[name.name='amountTone'] > Literal[value!=/^(?:auto|income|expense|savings|investment|neutral)$/]",
        "message": "<ListRow> amountTone must be one of 'auto' | 'income' | 'expense' | 'savings' | 'investment' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|tone|height|track|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, tone, height, track, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:income|expense|savings|investment|accent)$/]",
        "message": "<ProgressBar> tone must be one of 'income' | 'expense' | 'savings' | 'investment' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|placeholder|onChange|onClear|style|key|ref|className|style|children)$/]",
        "message": "<SearchBar> doesn't accept that prop. Declared props: value, placeholder, onChange, onClear, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|tone|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:income|expense|savings|investment|accent)$/]",
        "message": "<SegmentOption> tone must be one of 'income' | 'expense' | 'savings' | 'investment' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|currency|icon|tone|delta|emphasis|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, currency, icon, tone, delta, emphasis, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|income|expense|savings|investment)$/]",
        "message": "<StatCard> tone must be one of 'neutral' | 'income' | 'expense' | 'savings' | 'investment'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|style|key|ref|className|style|children)$/]",
        "message": "<StatusChip> doesn't accept that prop. Declared props: status, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:linked|parsed|unparsed)$/]",
        "message": "<StatusChip> status must be one of 'linked' | 'parsed' | 'unparsed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopAppBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|brand|onBack|showAvatar|avatarName|showBell|onBell|onAvatar|actions|style|key|ref|className|style|children)$/]",
        "message": "<TopAppBar> doesn't accept that prop. Declared props: title, brand, onBack, showAvatar, avatarName, showBell, onBell, onAvatar, actions, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
