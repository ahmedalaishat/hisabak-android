<!--
  UAE Dirham symbol (2025 mark): a Latin "D" with two horizontal bars through
  the stem. Tinted at the call site via Icon(tint = ...). If you have the
  official SVG, replace the pathData below — sizing/usage stays the same.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- D: vertical stem + bowl -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="2.3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M8,4 L8,20 M8,4 C15,4 18.5,7.6 18.5,12 C18.5,16.4 15,20 8,20" />
    <!-- two horizontal bars across the stem -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="2.3"
        android:strokeLineCap="round"
        android:pathData="M3.5,10.4 L11,10.4 M3.5,14 L11,14" />
</vector>
