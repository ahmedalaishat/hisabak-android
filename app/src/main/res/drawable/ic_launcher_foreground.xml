<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: an upward trend line ending in a mint data-point dot,
     over a faint area fill (growth / the app's dashboard charts). Matches the README
     and Play Store icon (docs/app-icon.svg), scaled into the 108dp adaptive safe zone
     so a circular mask never clips the dot. The themed/monochrome layer is a separate
     drawable (ic_launcher_monochrome) since the mint tone and translucency don't
     survive single-tint masking. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.10"
        android:pathData="M30,64 L46,49 L57,57 L78,36 L78,72 L30,72 Z" />
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5.1"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M30,64 L46,49 L57,57 L78,36" />
    <path
        android:fillColor="#95D4BB"
        android:pathData="M78,30.9 a5.1,5.1 0 1 0 0,10.2 a5.1,5.1 0 1 0 0,-10.2 z" />
</vector>
